legacy-peer-deps=true
strict-peer-dependencies=false
engine-strict=false
save-exact=false
save-prefix=^
registry=https://registry.npmjs.org/
npm-audit-resolve-level=moderate
audit=true
fund=false
progress=true
fetch-timeout=60000
fetch-retry-mintimeout=10000
fetch-retry-maxtimeout=120000
fetch-retries=3
loglevel=warn
prefer-offline=false
prefer-online=false
offline=false
scripts-prepend-node-path=auto
ignore-scripts=false
node-version=20.0.0
npm-version=10.0.0
